{% layout 'links' %}
{%- comment -%}
  Link na bio (link tree) da APP Agro Peças Padrão.
  Use no Instagram apontando para /pages/links.

  >> TROCAR o link do Mercado Livre abaixo na variável `ml_url`.
{%- endcomment -%}

{%- assign wa_msg = 'Olá! Vim pelo Instagram e gostaria de atendimento da Agro Peças Padrão.' -%}

{%- comment -%} ── COLE AQUI O LINK DA SUA LOJA NO MERCADO LIVRE ── {%- endcomment -%}
{%- assign ml_url = 'https://perfil.mercadolivre.com.br/AGROPECASPADRAO' -%}

<main class="wrap">

  <span class="status"><span class="dot"></span>Atendemos todo o Brasil</span>

  <div class="logo-ring">
    <img class="logo"
         src="{{ 'app-logo-circle.png' | asset_url }}"
         width="120" height="120"
         alt="APP Agro Peças Padrão">
  </div>

  <h1 class="brand">Agro Peças <span class="accent">Padrão</span></h1>
  <p class="tagline">Peças no padrão OEM. Entrega ágil. Confiança de verdade.</p>
  <div class="divider"></div>

  <nav class="links">

    {%- comment -%} ── WhatsApp ── {%- endcomment -%}
    <a class="btn btn--wa" href="https://wa.me/{{ settings.whatsapp_number }}?text={{ wa_msg | url_encode }}" target="_blank" rel="noopener">
      <span class="ico">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/>
        </svg>
      </span>
      <span class="txt"><b>WhatsApp</b><small>Fale com a equipe técnica</small></span>
      <span class="arw"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
    </a>

    {%- comment -%} ── Site / E-commerce (ícone = logo do app) ── {%- endcomment -%}
    <a class="btn btn--site" href="{{ routes.root_url }}" target="_blank" rel="noopener">
      <span class="ico">
        <img src="{{ 'logo_app_icon_v3.svg' | asset_url }}" width="32" height="32" alt="" loading="lazy">
      </span>
      <span class="txt"><b>Loja Online</b><small>Catálogo completo · compre pelo site</small></span>
      <span class="arw"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
    </a>

    {%- comment -%} ── Mercado Livre (símbolo handshake da marca) ── {%- endcomment -%}
    <a class="btn btn--ml" href="{{ ml_url }}" target="_blank" rel="noopener">
      <span class="ico">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m11 17 2 2a1 1 0 1 0 3-3"/>
          <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25H21"/>
          <path d="m21 3 1 11h-2"/>
          <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/>
          <path d="M3 4h8"/>
        </svg>
      </span>
      <span class="txt"><b>Mercado Livre</b><small>Compre com a segurança do ML</small></span>
      <span class="arw"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
    </a>

  </nav>

  <p class="foot">
    <b>APP Agro Peças Padrão</b><br>
    Padrão original / OEM · Entrega para todo o Brasil<br>
    CNPJ {{ settings.store_cnpj | default: '66.316.831/0001-85' }}
  </p>

</main>
