{%- comment -%}── BODY ──{%- endcomment -%}
<div class="ap-body">

  {%- comment -%}── SIDEBAR ──{%- endcomment -%}
  <aside class="ap-sidebar" id="ApSidebar">
    <div class="ap-sidebar__header">
      <svg viewBox="0 0 24 24"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/></svg>
      <span>Filtros</span>
    </div>

    {%- comment -%} Ordenar {%- endcomment -%}
    <div class="ap-filter-group">
      <p class="ap-filter-group__title">Ordenar por</p>
      {%- assign sort_by = collection.sort_by | default: 'manual' -%}
      <select class="ap-sort-select" onchange="window.location = this.value">
        <option value="{{ routes.all_products_collection_url }}?sort_by=manual"             {% if sort_by == 'manual'             %}selected{% endif %}>Em Destaque</option>
        <option value="{{ routes.all_products_collection_url }}?sort_by=title-ascending"    {% if sort_by == 'title-ascending'    %}selected{% endif %}>Nome A–Z</option>
        <option value="{{ routes.all_products_collection_url }}?sort_by=title-descending"   {% if sort_by == 'title-descending'   %}selected{% endif %}>Nome Z–A</option>
        <option value="{{ routes.all_products_collection_url }}?sort_by=created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>Mais Recentes</option>
      </select>
    </div>

    {%- comment -%} Categorias / coleções {%- endcomment -%}
    <div class="ap-filter-group">
      <p class="ap-filter-group__title">Categoria</p>
      <ul class="ap-filter-list">
        <li>
          <a href="{{ routes.all_products_collection_url }}"
             class="ap-filter-link {% unless current_tags %}is-active{% endunless %}">
            Todas as categorias
            <span class="count">{{ all_products.products_count }}</span>
          </a>
        </li>
        {%- for col in collections -%}
          {%- unless col.handle == 'frontpage' or col.handle == 'all' -%}
            <li>
              <a href="{{ col.url }}" class="ap-filter-link">
                {{ col.title }}
                <span class="count">{{ col.products_count }}</span>
              </a>
            </li>
          {%- endunless -%}
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} Disponibilidade {%- endcomment -%}
    <div class="ap-filter-group">
      <p class="ap-filter-group__title">Disponibilidade</p>
      <ul class="ap-filter-list">
        <li>
          <a href="{{ routes.all_products_collection_url }}"
             class="ap-filter-link {% unless current_tags contains 'disponivel' or current_tags contains 'baixo-estoque' %}is-active{% endunless %}">
            Todos
          </a>
        </li>
        <li>
          <a href="{{ routes.all_products_collection_url }}/disponivel"
             class="ap-filter-link {% if current_tags contains 'disponivel' %}is-active{% endif %}">
            <span class="ap-stock-dot ap-stock-dot--in"></span>Em Estoque
          </a>
        </li>
        <li>
          <a href="{{ routes.all_products_collection_url }}/baixo-estoque"
             class="ap-filter-link {% if current_tags contains 'baixo-estoque' %}is-active{% endif %}">
            <span class="ap-stock-dot ap-stock-dot--low"></span>Últimas Unidades
          </a>
        </li>
      </ul>
    </div>

    {%- comment -%} Compatibilidade {%- endcomment -%}
    <div class="ap-filter-group">
      <p class="ap-filter-group__title">Marca do Trator</p>
      {%- assign brands       = 'john-deere,new-holland,massey-ferguson,valtra,valmet' | split: ',' -%}
      {%- assign brand_labels = 'John Deere,New Holland,Massey Ferguson,Valtra,Valmet'  | split: ',' -%}
      <ul class="ap-filter-list">
        {%- for brand in brands -%}
          <li>
            <a href="{{ routes.all_products_collection_url }}/{{ brand }}"
               class="ap-filter-link {% if current_tags contains brand %}is-active{% endif %}">
              {{ brand_labels[forloop.index0] }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} Limpar filtros {%- endcomment -%}
    {%- if current_tags -%}
      <div class="ap-filter-group">
        <a href="{{ routes.all_products_collection_url }}" class="ap-filter-link ap-filter-link--danger">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          Limpar filtros
        </a>
      </div>
    {%- endif -%}
  </aside>

  {%- comment -%}── CONTENT ──{%- endcomment -%}
  <div class="ap-content">

    <div class="ap-toolbar">
      <div class="ap-toolbar__left">
        <button class="ap-btn-filter-toggle" id="ApFilterToggle" aria-expanded="false" aria-controls="ApSidebar">
          <svg viewBox="0 0 24 24"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/></svg>
          Filtros
        </button>
        <span class="ap-count">
          <strong>{{ all_products.products_count }}</strong> produtos encontrados
        </span>
      </div>
      {%- if current_tags -%}
        <div class="ap-active-filters">
          {%- for tag in current_tags -%}
            <a href="{{ routes.all_products_collection_url }}" class="ap-active-filter">
              {{ tag }}
              <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- paginate all_products.products by section.settings.products_per_page -%}
      {%- if all_products.products.size > 0 -%}
        <div class="product-grid product-grid--{{ section.settings.columns_desktop }}">
          {%- for product in all_products.products -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination ap-pagination" aria-label="Paginação">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="pagination__btn">← Anterior</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination__btn">{{ part.title }}</a>
              {%- else -%}
                <span class="pagination__current">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="pagination__btn">Próxima →</a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- else -%}
        <div class="ap-empty">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <h3>Nenhum produto encontrado</h3>
          <p>Tente remover os filtros ou buscar por outro termo.</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">Ver todos os produtos</a>
        </div>
      {%- endif -%}
    {%- endpaginate -%}

  </div>
</div>

<script>
  (function () {
    var toggle = document.getElementById('ApFilterToggle');
    var sidebar = document.getElementById('ApSidebar');
    if (!toggle || !sidebar) return;

    toggle.addEventListener('click', function () {
      var open = sidebar.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open);
    });

    // fechar ao clicar no overlay (shadow)
    sidebar.addEventListener('click', function (e) {
      if (e.target === sidebar) {
        sidebar.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', false);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Todos os Produtos",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24,
      "label": "Produtos por página"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Colunas (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    }
  ]
}
{% endschema %}
