<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {%- if template == 'index' -%}
      {{ shop.name }} — Bombas Hidráulicas e Sensores Agrícolas
    {%- elsif template == 'product' -%}
      {{ product.title }} | {{ shop.name }}
    {%- elsif template == 'collection' -%}
      {{ collection.title }} | {{ shop.name }}
    {%- elsif template == 'search' -%}
      Busca: {{ search.terms }} | {{ shop.name }}
    {%- else -%}
      {{ page_title }} | {{ shop.name }}
    {%- endif -%}
  </title>

  <meta name="description" content="{%- if page_description -%}{{ page_description | escape }}{%- else -%}Distribuidora especializada em bombas hidráulicas e sensores agrícolas com certificação ISO para tratores John Deere, New Holland, Massey Ferguson, Valtra e Valmet.{%- endif -%}">

  {%- render 'meta-tags' -%}
  <link rel="icon" type="image/svg+xml" href="{{ 'APP - LOGO ICON V3.svg' | asset_url }}">
  <link rel="apple-touch-icon" href="{{ 'APP - LOGO ICON V3.svg' | asset_url }}">

  {%- render 'ga4' -%}

  {{ content_for_header }}

  {{ 'fonts.css' | asset_url | stylesheet_tag }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'base.css' | asset_url | stylesheet_tag }}

  <style>
    /* Tokens dinâmicos — injetados a partir das configurações do tema */
    :root {
      --color-primary:        {{ settings.color_primary        | default: '#1B4332' }};
      --color-primary-dark:   {{ settings.color_primary_dark   | default: '#153628' }};
      --color-primary-hover:  {{ settings.color_primary_dark   | default: '#153628' }};
      --color-primary-mid:    {{ settings.color_primary_mid    | default: '#2F6B4F' }};
      --color-cta:            {{ settings.color_accent         | default: '#D4AF37' }};
      --color-cta-light:      {{ settings.color_accent_light   | default: '#E7C86A' }};
      --color-cta-dark:       {{ settings.color_accent_dark    | default: '#B8942B' }};
      /* aliases semânticos */
      --color-accent:         {{ settings.color_accent         | default: '#D4AF37' }};
      --color-accent-light:   {{ settings.color_accent_light   | default: '#E7C86A' }};
      --color-accent-dark:    {{ settings.color_accent_dark    | default: '#B8942B' }};
      --color-accent-green:   {{ settings.color_primary_mid    | default: '#2F6B4F' }};
      --color-bg-dark:        {{ settings.color_primary        | default: '#1B4332' }};
      --color-text:           {{ settings.color_text           | default: '#2F2F2F' }};
      --color-text-muted:     {{ settings.color_text_muted     | default: '#78716b' }};
      --color-text-soft:      {{ settings.color_text_muted     | default: '#78716b' }};
      --color-bg:             {{ settings.color_bg             | default: '#ffffff' }};
      --color-bg-soft:        {{ settings.color_bg_soft        | default: '#f9f8f7' }};
      --color-bg-stone:       #E6E1D9;
      --color-border:         {{ settings.color_border         | default: '#DCD7CE' }};
      --color-border-dark:    #CFC8BA;
      --color-stone-600:      #57534e;
      --color-stone-800:      #292524;
      --color-stone-900:      {{ settings.color_footer_bg      | default: '#1c1917' }};
      --color-whatsapp:       #25D366;
      --color-whatsapp-dark:  #1eb857;
      --color-success:        #22c55e;
      --color-error:          #C62828;
    }
  </style>

  <script>
    window.waNumber = {{ settings.whatsapp_number | json }};
    window.waGreeting = {{ settings.whatsapp_greeting | json }};
    window.shopName = {{ shop.name | json }};
  </script>
</head>

<body class="template-{{ template | replace: '.', '-' }}">

  {%- section 'header' -%}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <!-- WhatsApp flutuante -->
  <a href="https://wa.me/{{ settings.whatsapp_number }}?text={{ 'Olá! Preciso de atendimento do SAC da Agro Peças Padrão.' | url_encode }}"
     class="wa-float" target="_blank" rel="noopener" aria-label="Fale conosco pelo WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script src="{{ 'whatsapp.js' | asset_url }}" defer></script>

  {% comment %}── GA4: add_to_cart via form submit ───────────────────────{% endcomment %}
  {% if template == 'product' %}
  <script>
    document.addEventListener('submit', function (e) {
      var form = e.target.closest('form[action="/cart/add"]');
      if (!form) return;
      gtag('event', 'add_to_cart', {
        currency: {{ shop.currency | json }},
        value: {{ product.selected_or_first_available_variant.price | divided_by: 100.0 }},
        items: [{
          item_id:       {{ product.variants.first.sku | json }},
          item_name:     {{ product.title | json }},
          item_brand:    {{ product.vendor | json }},
          item_category: {{ product.type | json }},
          price:         {{ product.selected_or_first_available_variant.price | divided_by: 100.0 }},
          quantity:      parseInt(form.querySelector('[name="quantity"]')?.value || 1),
        }],
      });
    });
  </script>
  {% endif %}

</body>
</html>
