<style>
  .site-footer {
    background: #1B5E20;
    color: rgba(255,255,255,.8);
    margin-top: 80px;
  }

  .footer-main { padding: 56px 0 48px; }

  /* Grid: marca-grande | institucional | contato+pagamento | logo-grande */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  @media (min-width: 900px) {
    .footer-grid { grid-template-columns: 1.6fr 1fr 1.4fr; gap: 48px; align-items: start; }
  }

  /* ── COLUNA MARCA ── */
  .footer-brand { min-width: 0; }
  .footer-logo { margin-bottom: 14px; }
  .footer-logo img { width: auto; height: 72px; display: block; }
  .footer-logo__text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 20px;
    color: #fff;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .footer-tagline {
    font-size: 13px;
    color: rgba(255,255,255,.55);
    line-height: 1.7;
    margin: 0 0 20px;
    max-width: 280px;
  }

  /* WhatsApp SAC button */
  .footer-wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: #25D366;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 11px 18px;
    border-radius: var(--radius-full);
    transition: background 0.2s;
    margin-top: 4px;
  }
  .footer-wa-btn:hover { background: #1eb857; }
  .footer-wa-btn svg { flex-shrink: 0; }

  /* Social row below WA button */
  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }
  .footer-social__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255,255,255,.1);
    border: 1.5px solid rgba(255,255,255,.2);
    color: rgba(255,255,255,.75);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .footer-social__link:hover {
    background: #F57F17;
    border-color: #F57F17;
    color: #fff;
  }
  .footer-social__link svg { width: 16px; height: 16px; fill: currentColor; }

  /* ── COLUNA INSTITUCIONAL ── */
  .footer-col__title {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,.5);
    margin: 0 0 16px;
  }
  .footer-links ul { display: flex; flex-direction: column; gap: 10px; list-style: none; margin: 0; padding: 0; }
  .footer-links a { font-size: 14px; color: rgba(255,255,255,.7); transition: color 0.15s; }
  .footer-links a:hover { color: #fff; }

  /* ── COLUNA CONTATO + PAGAMENTO ── */
  .footer-contact-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: rgba(255,255,255,.65);
    line-height: 1.5;
  }
  .footer-contact-item svg {
    width: 14px; height: 14px; flex-shrink: 0; margin-top: 2px;
    fill: none; stroke: #F57F17; stroke-width: 2;
    stroke-linecap: round; stroke-linejoin: round;
  }
  .footer-contact-item a { color: rgba(255,255,255,.7); transition: color 0.15s; }
  .footer-contact-item a:hover { color: #fff; }

  /* Meios de pagamento */
  .footer-payment { margin-top: 20px; }
  .footer-payment__title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.4);
    margin: 0 0 10px;
  }
  .footer-payment-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .pay-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 28px;
    padding: 0 8px;
    background: #fff;
    border-radius: 4px;
    box-shadow: 0 1px 3px rgba(0,0,0,.2);
  }
  .pay-icon svg { display: block; height: 16px; width: auto; }
  .pay-icon--text {
    font-size: 9px;
    font-weight: 900;
    letter-spacing: 0.04em;
    font-family: var(--font-display);
    white-space: nowrap;
  }

  /* Segurança */
  .footer-secure {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    font-size: 11px;
    color: rgba(255,255,255,.4);
  }
  .footer-secure svg { stroke: rgba(255,255,255,.4); flex-shrink: 0; }
  .footer-secure strong { color: rgba(255,255,255,.6); }

  /* ── RODAPÉ INFERIOR ── */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,.1);
    padding: 18px 0;
  }
  .footer-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 12px;
    color: rgba(255,255,255,.35);
  }
  .footer-bottom__links { display: flex; gap: 20px; flex-wrap: wrap; }
  .footer-bottom__links a { color: rgba(255,255,255,.35); transition: color 0.15s; }
  .footer-bottom__links a:hover { color: rgba(255,255,255,.7); }
  .footer-badges { display: flex; gap: 8px; flex-wrap: wrap; }
  .trust-badge {
    padding: 3px 10px;
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 100px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,.35);
  }
</style>

