<div class="account-page">
  <div class="account-header">
    <div class="account-header__brand">
      <div class="account-header__icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </div>
      <div>
        <p style="font-size:12px;color:var(--color-text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.08em;margin-bottom:2px;">Bem-vindo,</p>
        <h1 class="account-header__title">{{ customer.first_name | default: 'Cliente' }} <em>{{ customer.last_name }}</em></h1>
      </div>
    </div>
    <a href="{{ routes.account_logout_url }}" class="account-logout">Sair da conta →</a>
  </div>

  <div class="account-orders">
    <h2 class="account-section-title">Meus Pedidos</h2>

    {%- if customer.orders.size > 0 -%}
      <table>
        <thead>
          <tr>
            <th>Pedido</th>
            <th>Data</th>
            <th>Status</th>
            <th>Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr>
              <td><strong style="font-family:var(--font-display);color:var(--color-primary);">#{{ order.order_number }}</strong></td>
              <td style="color:var(--color-text-muted);font-size:13px;">{{ order.created_at | date: '%d/%m/%Y' }}</td>
              <td>
                <span class="order-status order-status--{{ order.fulfillment_status | default: 'unfulfilled' }}">
                  {%- case order.fulfillment_status -%}
                    {%- when 'fulfilled' -%}Entregue
                    {%- when 'partial' -%}Parcial
                    {%- when 'restocked' -%}Devolvido
                    {%- else -%}Em andamento
                  {%- endcase -%}
                </span>
              </td>
              <td style="font-weight:700;">{{ order.total_price | money }}</td>
              <td>
                <a href="{{ order.customer_url }}" style="font-size:13px;color:var(--color-primary);font-weight:700;display:inline-flex;align-items:center;gap:4px;">
                  Ver detalhes
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    {%- else -%}
      <div class="account-empty">
        <div class="account-empty__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
          </svg>
        </div>
        <p style="font-weight:600;color:var(--color-text);margin-bottom:6px;">Nenhum pedido ainda</p>
        <p style="font-size:14px;margin-bottom:24px;">Explore nosso catálogo de peças originais LIVENZA e faça seu primeiro pedido.</p>
        <a href="{{ routes.root_url }}collections/all" class="btn btn--primary">Ver Catálogo de Peças</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Conta do Cliente",
  "settings": []
}
{% endschema %}
