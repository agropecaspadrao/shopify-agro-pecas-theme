{% layout 'links' %}
{%- comment -%}
  Link na bio (link tree) da APP Agro Peças Padrão.
  Use no Instagram apontando para /pages/links.

  >> TROCAR o link do Mercado Livre abaixo na variável `ml_url`.
{%- endcomment -%}

{%- assign wa_msg = 'Olá! Vim pelo Instagram e gostaria de atendimento da Agro Peças Padrão.' -%}

{%- comment -%} ── COLE AQUI O LINK DA SUA LOJA NO MERCADO LIVRE ── {%- endcomment -%}
{%- assign ml_url = 'https://perfil.mercadolivre.com.br/AGROPECASPADRAO' -%}

<main class="wrap">

  <div class="logo-ring">
    <img class="logo"
         src="{{ 'APP - LOGO Quadrada SEM FUNDO_circle_512px.png' | asset_url }}"
         width="116" height="116"
         alt="APP Agro Peças Padrão">
  </div>

  <h1 class="brand">Agro Peças <span class="accent">Padrão</span></h1>
  <p class="tagline">Bombas hidráulicas e peças no padrão original / OEM para o agronegócio.</p>
  <div class="divider"></div>

  <nav class="links">

    {%- comment -%} ── WhatsApp ── {%- endcomment -%}
    <a class="btn btn--wa" href="https://wa.me/{{ settings.whatsapp_number }}?text={{ wa_msg | url_encode }}" target="_blank" rel="noopener">
      <span class="ico">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </span>
      <span class="txt">WhatsApp<small>Fale com a equipe técnica</small></span>
      <span class="arw">→</span>
    </a>

    {%- comment -%} ── Site / E-commerce ── {%- endcomment -%}
    <a class="btn btn--site" href="{{ routes.root_url }}" target="_blank" rel="noopener">
      <span class="ico">
        <img src="{{ 'logo_app_icon_v3.svg' | asset_url }}" width="34" height="34" alt="" loading="lazy">
      </span>
      <span class="txt">Loja Online<small>Catálogo completo · compre pelo site</small></span>
      <span class="arw">→</span>
    </a>

    {%- comment -%} ── Mercado Livre ── {%- endcomment -%}
    <a class="btn btn--ml" href="{{ ml_url }}" target="_blank" rel="noopener">
      <span class="ico">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 3c-4.97 0-9 2.9-9 6.47 0 1.86 1.1 3.53 2.85 4.69-.2.72-.66 1.6-1.5 2.36-.16.15-.05.42.17.4 1.6-.13 2.96-.7 3.9-1.36 1.1.3 2.3.46 3.58.46 4.97 0 9-2.9 9-6.5C24 5.9 19.97 3 12 3z"/>
        </svg>
      </span>
      <span class="txt">Mercado Livre<small>Compre com a segurança do ML</small></span>
      <span class="arw">→</span>
    </a>

  </nav>

  <p class="foot">
    <b>APP Agro Peças Padrão</b><br>
    Padrão original / OEM · Entrega para todo o Brasil<br>
    CNPJ {{ settings.store_cnpj | default: '66.316.831/0001-85' }}
  </p>

</main>
