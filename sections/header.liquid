<header class="site-header" id="SiteHeader" role="banner">
  {%- if section.settings.announcement_text != blank -%}
    <div class="announcement-bar">
      <div class="page-width">
        <p>{{ section.settings.announcement_text }}</p>
      </div>
    </div>
  {%- endif -%}

  <div class="header-main">
    <div class="page-width header-inner">
      <!-- Logo oficial — header branco -->
      <a href="{{ routes.root_url }}" class="header-logo" aria-label="{{ shop.name }}">
        {%- if settings.logo -%}
          <img src="{{ settings.logo | image_url: width: 320 }}"
               alt="{{ shop.name }}"
               width="{{ section.settings.logo_width | default: 160 }}"
               height="56"
               loading="eager">
        {%- else -%}
          <img src="{{ 'APP - LOGO - SEM FUNDO V3.svg' | asset_url }}"
               alt="{{ shop.name }}"
               width="{{ section.settings.logo_width | default: 160 }}"
               height="56"
               loading="eager">
        {%- endif -%}
      </a>

      <!-- Search -->
      <div class="header-search">
        <form action="{{ routes.search_url }}" method="get" class="header-search__form" role="search">
          <input type="hidden" name="type" value="product">
          <input
            id="HeaderSearchInput"
            type="search"
            name="q"
            class="header-search__input"
            placeholder="Buscar por modelo, SKU ou referência OEM..."
            autocomplete="off"
            aria-label="Buscar produtos"
            value="{{ search.terms | escape }}"
          >
          <button type="submit" class="header-search__btn" aria-label="Buscar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </form>
        <div id="HeaderSearchResults" class="predictive-results" aria-live="polite" hidden></div>
      </div>

      <!-- Actions -->
      <div class="header-actions">
        <!-- Conta -->
        <a href="{{ routes.account_url }}" class="header-icon-btn" aria-label="Minha conta">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          <span class="hide-mobile">Conta</span>
        </a>

        <!-- Carrinho -->
        <a href="{{ routes.cart_url }}" class="header-icon-btn header-cart-btn" aria-label="Carrinho">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="header-cart-count">{{ cart.item_count }}</span>
          {%- endif -%}
          <span class="hide-mobile">Carrinho</span>
        </a>

        <!-- WhatsApp -->
        <a href="https://wa.me/{{ settings.whatsapp_number }}" class="btn-wa-header" target="_blank" rel="noopener" aria-label="Contato WhatsApp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="hide-mobile">Fale Conosco</span>
        </a>

        <button class="header-menu-toggle" id="MenuToggle" aria-expanded="false" aria-controls="MobileMenu" aria-label="Abrir menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Nav bar -->
    <nav class="header-nav" aria-label="Navegação principal">
      <div class="page-width">
        <ul class="header-nav__list">
          <li><a href="{{ routes.root_url }}" {% if template == 'index' %}aria-current="page"{% endif %}>Início</a></li>
          <li><a href="{{ routes.root_url }}collections/all" {% if collection.handle == 'all' %}aria-current="page"{% endif %}>Produtos</a></li>
          <li class="has-dropdown">
            <a href="{{ routes.collections_url }}" {% if template == 'list-collections' %}aria-current="page"{% endif %}>Catálogo</a>
            <ul class="header-nav__dropdown">
              {%- assign active_collection_handle = collection.handle -%}
              {%- for nav_collection in collections -%}
                <li><a href="{{ nav_collection.url }}" {% if nav_collection.handle == active_collection_handle %}aria-current="page"{% endif %}>{{ nav_collection.title }}</a></li>
              {%- endfor -%}
            </ul>
          </li>
          <li class="has-dropdown">
            <a href="{{ routes.root_url }}pages/quem-somos" {% if page.handle == 'quem-somos' %}aria-current="page"{% endif %}>Institucional</a>
            <ul class="header-nav__dropdown">
              <li><a href="{{ routes.root_url }}pages/quem-somos">Quem Somos Nós</a></li>
              <li><a href="{{ routes.root_url }}pages/politica-de-devolucao">Política de Devolução</a></li>
              <li><a href="{{ routes.root_url }}pages/politica-de-envio">Política de Envio</a></li>
            </ul>
          </li>
          <li><a href="{{ routes.root_url }}pages/contato" {% if page.handle == 'contato' %}aria-current="page"{% endif %}>Contato</a></li>
        </ul>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="MobileMenu" aria-hidden="true">
    <div class="mobile-menu__header">
      <span>Menu</span>
      <button class="mobile-menu__close" id="MenuClose" aria-label="Fechar menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <nav class="mobile-menu__nav">
      <a href="{{ routes.root_url }}" {% if template == 'index' %}aria-current="page"{% endif %}>Início</a>
      <a href="{{ routes.root_url }}collections/all" {% if collection.handle == 'all' %}aria-current="page"{% endif %}>Produtos</a>
      <a href="{{ routes.collections_url }}" {% if template == 'list-collections' %}aria-current="page"{% endif %}>Catálogo</a>
      <a href="{{ routes.root_url }}pages/quem-somos" {% if page.handle == 'quem-somos' %}aria-current="page"{% endif %}>Quem Somos Nós</a>
      <a href="{{ routes.root_url }}pages/politica-de-devolucao">Política de Devolução</a>
      <a href="{{ routes.root_url }}pages/politica-de-envio">Política de Envio</a>
      <a href="{{ routes.root_url }}pages/contato" {% if page.handle == 'contato' %}aria-current="page"{% endif %}>Contato</a>
    </nav>
    <div class="mobile-menu__footer">
      <a href="https://wa.me/{{ settings.whatsapp_number }}" class="btn btn--whatsapp btn--full" target="_blank" rel="noopener">
        WhatsApp — {{ settings.store_phone }}
      </a>
    </div>
  </div>
  <div class="mobile-menu__overlay" id="MenuOverlay"></div>
</header>

{% schema %}
{
  "name": "Cabeçalho",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 160,
      "unit": "px",
      "label": "Largura do Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu de Navegação",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Texto do Aviso (opcional)",
      "default": "Frete para todo o Brasil • Peças agrícolas originais • Atendimento técnico especializado"
    }
  ]
}
{% endschema %}
