<section class="hero-banner {% if section.settings.full_height %}hero-banner--full{% endif %}"
  style="{% if section.settings.bg_image != blank %}background-image: url('{{ section.settings.bg_image | image_url: width: 1600 }}');{% else %}background-image: url('{{ 'banner-agro.png' | asset_url }}');{% endif %}">
  <div class="hero-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  <div class="page-width hero-banner__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="hero-eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h1 class="hero-title">{{ section.settings.title }}</h1>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <div class="hero-ctas">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url }}" class="btn btn--primary btn--lg">
          {{ section.settings.cta_primary_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_wa_label != blank -%}
        <a href="https://wa.me/{{ settings.whatsapp_number }}" class="btn btn--whatsapp btn--lg" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {{ section.settings.cta_wa_label }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="trust-bar">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_item' -%}
            <div class="trust-item" {{ block.shopify_attributes }}>
              <span class="trust-item__icon">{{ block.settings.icon }}</span>
              <span class="trust-item__text">{{ block.settings.text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Banner Principal",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Imagem de Fundo"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 55,
      "unit": "%",
      "label": "Opacidade do Overlay"
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Altura Total da Tela",
      "default": false
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto Acima do Título",
      "default": "Distribuidor Oficial LIVENZA • Certificação ISO 9001"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Bombas Hidráulicas e Sensores para o Campo"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Peças originais para John Deere, New Holland, Massey Ferguson, Valtra e Valmet. Estoque pronto entrega, envio para todo o Brasil."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Botão Principal — Texto",
      "default": "Ver Catálogo"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Botão Principal — Link"
    },
    {
      "type": "text",
      "id": "cta_wa_label",
      "label": "Botão WhatsApp — Texto",
      "default": "Pedir Cotação"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Item de Confiança",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Ícone (emoji)",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Certificação ISO"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Principal",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "🏆", "text": "ISO 9001 / 14001 / 18001" } },
        { "type": "trust_item", "settings": { "icon": "🚚", "text": "Entrega p/ todo Brasil" } },
        { "type": "trust_item", "settings": { "icon": "📦", "text": "Estoque Disponível" } },
        { "type": "trust_item", "settings": { "icon": "🔧", "text": "Suporte Técnico" } }
      ]
    }
  ]
}
{% endschema %}
