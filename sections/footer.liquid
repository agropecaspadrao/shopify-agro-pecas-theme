<footer class="site-footer">
  <div class="footer-main">
    <div class="page-width footer-grid">

      <!-- Brand col -->
      <div class="footer-brand">
        <div class="footer-logo">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" width="160" height="auto" loading="lazy">
          {%- else -%}
            <span class="footer-logo__text">{{ shop.name }}</span>
          {%- endif -%}
        </div>
        <p class="footer-tagline">{{ settings.footer_tagline }}</p>
        <div class="footer-contact">
          {%- if settings.store_cnpj != blank -%}
            <p><strong>CNPJ:</strong> {{ settings.store_cnpj }}</p>
          {%- endif -%}
          {%- if settings.store_address != blank -%}
            <p>{{ settings.store_address }}</p>
          {%- endif -%}
          {%- if settings.store_phone != blank -%}
            <p><a href="tel:{{ settings.store_phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}">{{ settings.store_phone }}</a></p>
          {%- endif -%}
          {%- if settings.store_email != blank -%}
            <p><a href="mailto:{{ settings.store_email }}">{{ settings.store_email }}</a></p>
          {%- endif -%}
        </div>
      </div>

      <!-- Link cols -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer-links" {{ block.shopify_attributes }}>
            <h4 class="footer-links__title">{{ block.settings.heading }}</h4>
            <ul>
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- elsif block.type == 'contact' -%}
          <div class="footer-contact-block" {{ block.shopify_attributes }}>
            <h4 class="footer-links__title">{{ block.settings.heading }}</h4>
            <p>{{ block.settings.description }}</p>
            <a href="https://wa.me/{{ settings.whatsapp_number }}" class="btn btn--whatsapp btn--sm" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chamar no WhatsApp
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>

  <div class="footer-bottom">
    <div class="page-width footer-bottom__inner">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos os direitos reservados.</p>
      <div class="footer-badges">
        <span class="trust-badge">ISO 9001</span>
        <span class="trust-badge">ISO 14001</span>
        <span class="trust-badge">OHSAS 18001</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Rodapé",
  "max_blocks": 6,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo no Rodapé"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu de Links",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contato",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Atendimento"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrição",
          "default": "Atendemos distribuidores, revendas e frota própria em todo o Brasil."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rodapé Padrão",
      "blocks": [
        {
          "type": "link_list",
          "settings": {
            "heading": "Produtos",
            "menu": "footer-produtos"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Institucional",
            "menu": "footer-institucional"
          }
        },
        {
          "type": "contact",
          "settings": {
            "heading": "Atendimento"
          }
        }
      ]
    }
  ]
}
{% endschema %}
