<section class="not-found section-padding">
  <div class="page-width not-found__inner">
    <img
      src="{{ 'APP - LOGO ICON V3.svg' | asset_url }}"
      alt=""
      width="72"
      height="72"
      loading="eager"
      class="not-found__icon"
    >
    <p class="section-eyebrow">Erro 404</p>
    <h1 class="not-found__title">Página não encontrada</h1>
    <p class="not-found__text">
      O endereço acessado não está disponível. Use a busca ou volte ao catálogo para encontrar a peça agrícola correta.
    </p>

    <form action="{{ routes.search_url }}" method="get" class="not-found__search" role="search">
      <input type="hidden" name="type" value="product">
      <input
        type="search"
        name="q"
        placeholder="Buscar por SKU, referência OEM ou modelo..."
        aria-label="Buscar produtos"
      >
      <button type="submit" class="btn btn--primary">Buscar</button>
    </form>

    <div class="not-found__actions">
      <a href="{{ routes.root_url }}collections/all" class="btn btn--primary">Ver catálogo</a>
      <a href="{{ routes.root_url }}" class="btn btn--outline">Voltar ao início</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Página 404",
  "settings": []
}
{% endschema %}
