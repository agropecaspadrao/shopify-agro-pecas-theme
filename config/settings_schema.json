[
  {
    "name": "theme_info",
    "theme_name": "APP Agro Peças Padrão",
    "theme_version": "1.1.0",
    "theme_author": "APP Agro Peças",
    "theme_documentation_url": "https://github.com/agropecaspadrao/shopify-agro-pecas-theme",
    "theme_support_url": "https://github.com/agropecaspadrao/shopify-agro-pecas-theme/issues"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo da loja",
        "info": "Recomendado: APP - LOGO - SEM FUNDO V3.svg. Use o logo com fundo transparente para melhor resultado."
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Largura do logo (px)",
        "min": 80,
        "max": 300,
        "step": 4,
        "default": 160
      },
      {
        "type": "image_picker",
        "id": "logo_white",
        "label": "Logo versão branca",
        "info": "Versão do logo para fundos escuros (footer, painéis de auth). Recomendado: logo-branca.png"
      }
    ]
  },
  {
    "name": "Cores",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Cor Primária (Verde Floresta)",
        "default": "#1B4332",
        "info": "Cor principal — headers, botões CTA, backgrounds escuros."
      },
      {
        "type": "color",
        "id": "color_primary_dark",
        "label": "Cor Primária Escura (Verde Escuro)",
        "default": "#153628",
        "info": "Hover states, versão mais densa do primário."
      },
      {
        "type": "color",
        "id": "color_primary_mid",
        "label": "Cor Primária Média (Verde Médio)",
        "default": "#2F6B4F",
        "info": "Gradientes, variações do primário."
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Cor de Destaque (Dourado Premium)",
        "default": "#D4AF37",
        "info": "Accent — destaques, badges, ícones, CTAs secundários."
      },
      {
        "type": "color",
        "id": "color_accent_light",
        "label": "Cor de Destaque Clara (Dourado Claro)",
        "default": "#E7C86A",
        "info": "Trust icons, elementos decorativos em fundos escuros."
      },
      {
        "type": "color",
        "id": "color_accent_dark",
        "label": "Cor de Destaque Escura (Dourado Dark)",
        "default": "#B8942B",
        "info": "Hover do accent."
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Cor do Texto Principal",
        "default": "#212121"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Cor do Texto Suave",
        "default": "#78716b",
        "info": "Labels, metadados, textos secundários."
      },
      {
        "type": "color",
        "id": "color_bg",
        "label": "Cor de Fundo",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_bg_soft",
        "label": "Cor de Fundo Suave",
        "default": "#f9f8f7",
        "info": "Seções zebradas, backgrounds de cards."
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Cor de Borda",
        "default": "#e7e5e3",
        "info": "Divisores, bordas de input."
      },
      {
        "type": "color",
        "id": "color_footer_bg",
        "label": "Cor de Fundo do Rodapé",
        "default": "#1c1917",
        "info": "Stone 900 — rodapé escuro."
      }
    ]
  },
  {
    "name": "Tipografia",
    "settings": [
      {
        "type": "select",
        "id": "font_heading",
        "label": "Fonte de Títulos",
        "options": [
          { "value": "barlow-condensed", "label": "Barlow Condensed (padrão da marca)" },
          { "value": "system", "label": "Fonte do sistema" }
        ],
        "default": "barlow-condensed",
        "info": "Barlow Condensed é a fonte oficial da identidade visual da APP Agro Peças Padrão."
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Tamanho base do texto (px)",
        "min": 14,
        "max": 18,
        "step": 1,
        "default": 15
      }
    ]
  },
  {
    "name": "Marca",
    "settings": [
      {
        "type": "text",
        "id": "brand_tagline",
        "label": "Tagline Principal",
        "default": "Peças originais. Entrega ágil. Confiança de verdade.",
        "info": "Exibida em banners, seção hero e metadados SEO."
      },
      {
        "type": "text",
        "id": "brand_tagline_footer",
        "label": "Tagline do Rodapé",
        "default": "Especialistas em bombas hidráulicas e peças para o agronegócio brasileiro.",
        "info": "Slogan secundário exibido no footer."
      },
      {
        "type": "text",
        "id": "brand_distributor",
        "label": "Distribuidor Oficial",
        "default": "LIVENZA",
        "info": "Nome exibido em badges de confiança e painéis de autenticação."
      },
      {
        "type": "text",
        "id": "brand_iso_cert",
        "label": "Certificações ISO",
        "default": "ISO 9001 · ISO 14001 · ISO 18001",
        "info": "Certificações exibidas em selos de confiança na PDP."
      }
    ]
  },
  {
    "name": "WhatsApp",
    "settings": [
      {
        "type": "text",
        "id": "whatsapp_number",
        "label": "Número WhatsApp (com DDI)",
        "default": "5541983333338",
        "info": "Somente números, ex: 5541999999999"
      },
      {
        "type": "text",
        "id": "whatsapp_greeting",
        "label": "Saudação padrão",
        "default": "Olá! Gostaria de mais informações sobre as peças que encontrei no Site."
      }
    ]
  },
  {
    "name": "Informações da Loja",
    "settings": [
      {
        "type": "text",
        "id": "store_cnpj",
        "label": "CNPJ",
        "default": "66.316.831/0001-85"
      },
      {
        "type": "text",
        "id": "store_address",
        "label": "Endereço",
        "default": "R. José Benedito Cottolengo, 901 — Casa 19, Cond. Jardim de Monet, Campo Comprido, Curitiba – PR, CEP 81.220-310"
      },
      {
        "type": "text",
        "id": "store_phone",
        "label": "Telefone",
        "default": "+55 41 99833-3338"
      },
      {
        "type": "text",
        "id": "store_email",
        "label": "E-mail",
        "default": "comercial@agropecaspadrao.com.br"
      }
    ]
  },
  {
    "name": "Rodapé",
    "settings": [
      {
        "type": "text",
        "id": "footer_tagline",
        "label": "Slogan do Rodapé",
        "default": "Peças hidráulicas e sensores agrícolas com certificação ISO para máquinas do campo."
      }
    ]
  }
]
