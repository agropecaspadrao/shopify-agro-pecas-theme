{% layout 'theme' %}

<div class="cotacao-page">
  <div class="page-width">
    <div class="cotacao-layout">

      <!-- Form -->
      <div class="cotacao-form-col">
        <div class="section-header">
          <span class="section-eyebrow">B2B</span>
          <h1 class="section-title">Solicitar Cotação</h1>
          <p class="section-desc">Preencha o formulário e nossa equipe responderá em até 2 horas úteis com disponibilidade e condições de pagamento.</p>
        </div>

        {%- form 'contact', id: 'ContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-success" role="alert">
              <div class="form-success__icon">✓</div>
              <h3>Cotação Enviada!</h3>
              <p>Sua solicitação foi recebida. Entraremos em contato em breve pelo e-mail ou telefone informado.</p>
              <a href="{{ routes.root_url }}" class="btn btn--primary">Voltar ao Início</a>
            </div>
          {%- else -%}
            <div class="form-grid">
              <!-- Nome -->
              <div class="form-field">
                <label for="ContactName" class="form-label">Nome Completo *</label>
                <input type="text" id="ContactName" name="contact[name]" class="form-input" required autocomplete="name">
              </div>

              <!-- Empresa -->
              <div class="form-field">
                <label for="ContactCompany" class="form-label">Empresa</label>
                <input type="text" id="ContactCompany" name="contact[empresa]" class="form-input" autocomplete="organization">
              </div>

              <!-- CNPJ -->
              <div class="form-field">
                <label for="ContactCNPJ" class="form-label">CNPJ</label>
                <input type="text" id="ContactCNPJ" name="contact[cnpj]" class="form-input" placeholder="00.000.000/0001-00">
              </div>

              <!-- Telefone -->
              <div class="form-field">
                <label for="ContactPhone" class="form-label">Telefone / WhatsApp *</label>
                <input type="tel" id="ContactPhone" name="contact[phone]" class="form-input" required autocomplete="tel">
              </div>

              <!-- Email -->
              <div class="form-field form-field--full">
                <label for="ContactEmail" class="form-label">E-mail *</label>
                <input type="email" id="ContactEmail" name="contact[email]" class="form-input" required autocomplete="email">
              </div>

              <!-- Produto -->
              <div class="form-field form-field--full">
                <label for="ContactProduct" class="form-label">Produto / Peça</label>
                <input type="text" id="ContactProduct" name="contact[produto]" class="form-input" placeholder="Nome ou descrição da peça">
              </div>

              <!-- SKU -->
              <div class="form-field">
                <label for="ContactSKU" class="form-label">SKU / Referência</label>
                <input type="text" id="ContactSKU" name="contact[sku]" class="form-input" placeholder="Ex: 5.1305.0565071">
              </div>

              <!-- Quantidade -->
              <div class="form-field">
                <label for="ContactQty" class="form-label">Quantidade</label>
                <input type="number" id="ContactQty" name="contact[quantidade]" class="form-input" min="1" value="1">
              </div>

              <!-- Prazo -->
              <div class="form-field">
                <label for="ContactDeadline" class="form-label">Prazo Necessário</label>
                <select id="ContactDeadline" name="contact[prazo]" class="form-select">
                  <option value="">Selecione...</option>
                  <option value="urgente">Urgente (1-3 dias)</option>
                  <option value="1-semana">Até 1 semana</option>
                  <option value="2-semanas">Até 2 semanas</option>
                  <option value="1-mes">Até 1 mês</option>
                  <option value="flexivel">Flexível</option>
                </select>
              </div>

              <!-- Observações -->
              <div class="form-field form-field--full">
                <label for="ContactBody" class="form-label">Observações</label>
                <textarea id="ContactBody" name="contact[body]" class="form-textarea" rows="4" placeholder="Modelo do trator, condições especiais, outras informações..."></textarea>
              </div>
            </div>

            <button type="submit" class="btn btn--primary btn--lg btn--full">
              Enviar Solicitação de Cotação
            </button>

            <p class="form-disclaimer">
              Ao enviar, você concorda que entraremos em contato pelo e-mail ou telefone fornecido.
            </p>
          {%- endif -%}
        {%- endform -%}
      </div>

      <!-- Sidebar -->
      <aside class="cotacao-sidebar">
        <div class="cotacao-benefits">
          <h3>Por que cotação?</h3>
          <ul class="benefits-list">
            <li>
              <span class="benefit-icon">💼</span>
              <div>
                <strong>Preços especiais B2B</strong>
                <p>Condições diferenciadas para distribuidores, revendas e frotas.</p>
              </div>
            </li>
            <li>
              <span class="benefit-icon">📦</span>
              <div>
                <strong>Compras em volume</strong>
                <p>Descontos progressivos para pedidos maiores.</p>
              </div>
            </li>
            <li>
              <span class="benefit-icon">🔧</span>
              <div>
                <strong>Suporte técnico</strong>
                <p>Ajuda para identificar a peça correta para sua máquina.</p>
              </div>
            </li>
            <li>
              <span class="benefit-icon">🚚</span>
              <div>
                <strong>Logística dedicada</strong>
                <p>Frete negociado para grandes volumes.</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="cotacao-wa-alt">
          <p>Prefere resolver agora?</p>
          <a href="https://wa.me/{{ settings.whatsapp_number }}" class="btn btn--whatsapp btn--full" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Chamar no WhatsApp
          </a>
        </div>
      </aside>
    </div>
  </div>
</div>

<script>
  // Pre-fill from URL params (e.g. from PDP links)
  (function() {
    var params = new URLSearchParams(window.location.search);
    var productField = document.getElementById('ContactProduct');
    var skuField = document.getElementById('ContactSKU');
    if (productField && params.get('product')) productField.value = decodeURIComponent(params.get('product'));
    if (skuField && params.get('sku')) skuField.value = decodeURIComponent(params.get('sku'));
  })();
</script>
