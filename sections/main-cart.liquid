<style>
  .cart-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .cart-page__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 2px solid var(--color-border);
  }

  .cart-page__title em { font-style: normal; color: var(--color-accent); }

  .cart-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .cart-layout { grid-template-columns: 1fr 340px; }
  }

  /* ── ITENS ── */
  .cart-items { display: flex; flex-direction: column; gap: 0; }

  .cart-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 16px;
    align-items: start;
    padding: 20px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .cart-item__img {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg-soft);
    flex-shrink: 0;
  }

  .cart-item__img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 4px;
  }

  .cart-item__info { flex: 1; }

  .cart-item__vendor {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 4px;
  }

  .cart-item__title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 6px;
  }

  .cart-item__sku {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-bottom: 12px;
  }

  .cart-item__qty {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .cart-item__qty button {
    width: 34px;
    height: 34px;
    background: transparent;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .cart-item__qty button:hover { background: var(--color-bg-soft); }

  .cart-item__qty input {
    width: 40px;
    text-align: center;
    border: none;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    font-size: 14px;
    font-weight: 600;
    padding: 6px 0;
    outline: none;
    background: transparent;
  }

  .cart-item__price {
    text-align: right;
    flex-shrink: 0;
  }

  .cart-item__price--total {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    color: var(--color-primary);
  }

  .cart-item__remove {
    display: block;
    margin-top: 8px;
    font-size: 12px;
    color: var(--color-text-muted);
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  /* ── RESUMO ── */
  .cart-summary {
    background: var(--color-bg-soft);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    position: sticky;
    top: 100px;
    height: fit-content;
  }

  .cart-summary__title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text);
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-border);
  }

  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    color: var(--color-text-muted);
    margin-bottom: 10px;
  }

  .cart-summary__row--total {
    font-size: 18px;
    font-weight: 800;
    color: var(--color-text);
    margin-top: 16px;
    padding-top: 16px;
    border-top: 2px solid var(--color-border);
    margin-bottom: 20px;
  }

  .cart-summary__note {
    font-size: 12px;
    color: var(--color-text-muted);
    text-align: center;
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .cart-checkout-btn {
    display: block;
    width: 100%;
    padding: 16px;
    background: var(--color-primary);
    color: #fff;
    text-align: center;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
  }

  .cart-checkout-btn:hover { background: var(--color-primary-dark); }

  .cart-continue {
    display: block;
    text-align: center;
    margin-top: 14px;
    font-size: 13px;
    color: var(--color-text-muted);
    text-decoration: underline;
  }

  /* ── CARRINHO VAZIO ── */
  .cart-empty {
    text-align: center;
    padding: 80px 24px;
  }

  .cart-empty__icon {
    font-size: 64px;
    margin-bottom: 20px;
  }

  .cart-empty__title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .cart-empty p {
    color: var(--color-text-muted);
    margin-bottom: 28px;
  }

  /* Métodos de pagamento */
  .cart-payment-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-top: 16px;
  }

  .cart-payment-icon {
    padding: 3px 8px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
</style>

<div class="cart-page">
  <h1 class="cart-page__title">Meu <em>Carrinho</em></h1>

  {%- if cart.item_count > 0 -%}
    <div class="cart-layout">
      <!-- Itens -->
      <div>
        {%- form 'cart', cart -%}
          <div class="cart-items">
            {%- for item in cart.items -%}
              <div class="cart-item">
                <a href="{{ item.url }}" class="cart-item__img">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" loading="lazy">
                  {%- endif -%}
                </a>
                <div class="cart-item__info">
                  <div class="cart-item__vendor">{{ item.vendor }}</div>
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.title }}</a>
                  {%- if item.sku != blank -%}
                    <div class="cart-item__sku">SKU: {{ item.sku }}</div>
                  {%- endif -%}
                  <div class="cart-item__qty">
                    <button type="button" class="qty-btn" data-action="decrease" data-line="{{ forloop.index }}">−</button>
                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantidade">
                    <button type="button" class="qty-btn" data-action="increase" data-line="{{ forloop.index }}">+</button>
                  </div>
                </div>
                <div class="cart-item__price">
                  <div class="cart-item__price--total">{{ item.final_line_price | money }}</div>
                  {%- if item.quantity > 1 -%}
                    <div style="font-size:12px; color:var(--color-text-muted); margin-top:4px;">{{ item.final_price | money }} cada</div>
                  {%- endif -%}
                  <button type="button" class="cart-item__remove" data-line="{{ forloop.index }}">Remover</button>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <input type="hidden" name="checkout" value="">
        {%- endform -%}
      </div>

      <!-- Resumo -->
      <div class="cart-summary">
        <div class="cart-summary__title">Resumo</div>
        <div class="cart-summary__row">
          <span>Subtotal ({{ cart.item_count }} {%- if cart.item_count == 1 -%} item{%- else -%} itens{%- endif -%})</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="cart-summary__row">
          <span>Frete</span>
          <span>Calculado no checkout</span>
        </div>
        <div class="cart-summary__row cart-summary__row--total">
          <span>Total</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <p class="cart-summary__note">Impostos e frete calculados no checkout. Parcele em até 12x no cartão.</p>
        <a href="/checkout" class="cart-checkout-btn">Finalizar Compra →</a>
        <a href="{{ routes.root_url }}collections/all" class="cart-continue">← Continuar comprando</a>

        <div class="cart-payment-icons">
          <span class="cart-payment-icon">VISA</span>
          <span class="cart-payment-icon">MASTER</span>
          <span class="cart-payment-icon">PIX</span>
          <span class="cart-payment-icon">BOLETO</span>
          <span class="cart-payment-icon">AMEX</span>
        </div>
      </div>
    </div>

  {%- else -%}
    <div class="cart-empty">
      <div class="cart-empty__icon">🛒</div>
      <h2 class="cart-empty__title">Carrinho vazio</h2>
      <p>Você ainda não adicionou nenhum produto ao carrinho.</p>
      <a href="{{ routes.root_url }}collections/all" class="btn btn--primary btn--lg">Ver Catálogo</a>
    </div>
  {%- endif -%}
</div>

<script>
(function () {
  document.addEventListener('click', function (e) {
    var removeBtn = e.target.closest('.cart-item__remove');
    if (removeBtn) {
      var line = removeBtn.dataset.line;
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: parseInt(line), quantity: 0 })
      }).then(function () { window.location.reload(); });
    }

    var qtyBtn = e.target.closest('.qty-btn');
    if (qtyBtn) {
      var action = qtyBtn.dataset.action;
      var input = qtyBtn.closest('.cart-item__qty').querySelector('input');
      var currentQty = parseInt(input.value) || 1;
      var newQty = action === 'increase' ? currentQty + 1 : Math.max(0, currentQty - 1);
      var line = qtyBtn.dataset.line;
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: parseInt(line), quantity: newQty })
      }).then(function () { window.location.reload(); });
    }
  });
})();
</script>

{% schema %}
{
  "name": "Carrinho",
  "settings": []
}
{% endschema %}
