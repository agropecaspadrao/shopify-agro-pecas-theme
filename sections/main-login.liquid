
<div class="auth-page">
  <div class="auth-box">
    <span class="auth-box__eyebrow">Acesso à conta</span>
    <h1 class="auth-box__title">Entrar na <em>conta</em></h1>

    {%- if form.errors -%}
      <ul class="auth-errors">
        {%- for error in form.errors -%}
          <li>{{ form.errors.messages[error] }}</li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- form 'customer_login' -%}
      <div class="auth-field">
        <label for="CustomerEmail">E-mail</label>
        <input type="email" name="customer[email]" id="CustomerEmail" autocomplete="email" autocorrect="off" autocapitalize="off" placeholder="seu@email.com.br" required>
      </div>
      <div class="auth-field">
        <label for="CustomerPassword">Senha</label>
        <input type="password" name="customer[password]" id="CustomerPassword" autocomplete="current-password" placeholder="••••••••" required>
      </div>
      <a href="{{ routes.account_login_url }}#recover" class="auth-forgot">Esqueceu a senha?</a>
      <button type="submit" class="auth-submit">Entrar</button>
    {%- endform -%}

    <div class="auth-divider">ou</div>
    <a href="{{ routes.account_register_url }}" class="auth-link-btn">Criar conta</a>
  </div>
</div>

{%- if section.id == 'main' -%}
<style>
  #recover-password { display: none; }
  #recover-password.is-active { display: block; }
  #login-form.is-hidden { display: none; }
</style>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (window.location.hash === '#recover') {
      document.getElementById('recover-password')?.classList.add('is-active');
      document.getElementById('login-form')?.classList.add('is-hidden');
    }
  });
</script>
{%- endif -%}

{% schema %}
{
  "name": "Login",
  "settings": []
}
{% endschema %}
