<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{{ page_title }} | {{ shop.name }}</title>
  <meta name="description" content="Links oficiais da APP Agro Peças Padrão — WhatsApp, loja online e Mercado Livre. Bombas hidráulicas e peças no padrão original / OEM para o agronegócio.">

  {%- render 'meta-tags' -%}
  <link rel="icon" type="image/svg+xml" href="{{ 'logo_app_icon_v3.svg' | asset_url }}">
  <link rel="apple-touch-icon" href="{{ 'logo_app_icon_v3.svg' | asset_url }}">

  {{ content_for_header }}
  {{ 'fonts.css' | asset_url | stylesheet_tag }}

  <style>
    :root{
      --green:        {{ settings.color_primary      | default: '#1B4332' }};
      --green-dark:   {{ settings.color_primary_dark | default: '#153628' }};
      --green-mid:    {{ settings.color_primary_mid  | default: '#2F6B4F' }};
      --gold:         {{ settings.color_accent       | default: '#D4AF37' }};
      --gold-light:   {{ settings.color_accent_light | default: '#E7C86A' }};
      --whatsapp:     #25D366;
      --ml-yellow:    #FFE600;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-text-size-adjust:100%}
    body{
      font-family:'Barlow',system-ui,sans-serif;
      min-height:100dvh;
      color:#fff;
      background:
        radial-gradient(110% 60% at 50% 0%, var(--green-mid) 0%, transparent 55%),
        linear-gradient(160deg, var(--green) 0%, var(--green-dark) 100%);
      display:flex;
      flex-direction:column;
      align-items:center;
      padding:max(40px,env(safe-area-inset-top)) 20px max(40px,env(safe-area-inset-bottom));
    }
    .wrap{
      width:100%;
      max-width:440px;
      margin:auto;
      display:flex;
      flex-direction:column;
      align-items:center;
    }

    /* ── Cabeçalho / marca ── */
    .logo{
      width:120px;height:120px;border-radius:50%;
      object-fit:cover;
      border:3px solid var(--gold);
      box-shadow:0 10px 40px rgba(0,0,0,.45);
      background:#fff;
    }
    .brand{
      font-family:'Barlow Condensed',sans-serif;
      font-weight:700;
      font-size:30px;
      letter-spacing:.04em;
      text-transform:uppercase;
      text-align:center;
      margin-top:20px;
      line-height:1.05;
    }
    .brand .accent{color:var(--gold-light)}
    .tagline{
      margin-top:10px;
      text-align:center;
      font-size:14.5px;
      font-weight:500;
      color:rgba(255,255,255,.78);
      max-width:300px;
      line-height:1.45;
    }
    .divider{
      width:54px;height:3px;border-radius:2px;
      background:var(--gold);
      margin:22px 0 26px;
    }

    /* ── Botões ── */
    .links{width:100%;display:flex;flex-direction:column;gap:14px}
    .btn{
      display:flex;align-items:center;gap:14px;
      width:100%;
      padding:16px 20px;
      border-radius:14px;
      text-decoration:none;
      font-weight:600;
      font-size:16.5px;
      background:#fff;color:var(--green-dark);
      box-shadow:0 4px 18px rgba(0,0,0,.22);
      transition:transform .15s ease, box-shadow .15s ease, filter .15s ease;
      border:1px solid rgba(0,0,0,.04);
    }
    .btn:hover{transform:translateY(-2px);box-shadow:0 8px 26px rgba(0,0,0,.32)}
    .btn:active{transform:translateY(0)}
    .btn .ico{flex:0 0 30px;width:30px;height:30px;display:flex;align-items:center;justify-content:center}
    .btn .txt{flex:1}
    .btn .txt small{display:block;font-weight:500;font-size:12.5px;opacity:.62;letter-spacing:.01em}
    .btn .arw{opacity:.4;flex:0 0 auto}

    .btn--wa{background:var(--whatsapp);color:#fff}
    .btn--wa .txt small{opacity:.85}
    .btn--wa .arw{opacity:.7}
    .btn--site{background:var(--gold);color:var(--green-dark)}
    .btn--ml{background:var(--ml-yellow);color:#2D3277}

    /* ── Rodapé ── */
    .foot{
      margin-top:30px;text-align:center;
      font-size:12px;color:rgba(255,255,255,.55);
      line-height:1.7;
    }
    .foot b{color:rgba(255,255,255,.8);font-weight:600}

    @media (max-width:360px){
      .brand{font-size:26px}
      .btn{font-size:15.5px;padding:15px 17px}
    }
  </style>
</head>
<body>
  {{ content_for_layout }}
</body>
</html>
