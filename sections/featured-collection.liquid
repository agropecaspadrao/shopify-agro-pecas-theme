{% comment %}
  Produtos em Destaque — lógica:
  1. Prioridade: produtos com compare_at_price > price (desconto configurado no Shopify),
     ordenados pelo maior % de desconto.
  2. Fallback: top 3 por estoque de cada coleção ativa, rotacionados em carrossel de 5s.
{% endcomment %}

{%- comment -%}── Coleta produtos com desconto real ──{%- endcomment -%}
{%- assign discounted = '' -%}
{%- for product in collections.all.products -%}
  {%- if product.compare_at_price > product.price -%}
    {%- assign discounted = discounted | append: product.id | append: ',' -%}
  {%- endif -%}
{%- endfor -%}
{%- assign has_discounts = false -%}
{%- if discounted != '' -%}
  {%- assign has_discounts = true -%}
{%- endif -%}

{%- comment -%}── Coleções para o carrossel (exclui frontpage e all) ──{%- endcomment -%}
{%- assign carousel_collections = '' -%}
{%- for col in collections -%}
  {%- unless col.handle == 'frontpage' or col.handle == 'all' or col.products_count == 0 -%}
    {%- assign carousel_collections = carousel_collections | append: col.handle | append: ',' -%}
  {%- endunless -%}
{%- endfor -%}
{%- assign carousel_collections = carousel_collections | split: ',' | compact -%}

<section class="fd-section" id="FeaturedSection">
<style>
  .fd-section {
    background: var(--color-bg, #f5f4f0);
    padding: 64px 0 72px;
  }

  /* ── HEADER ── */
  .fd-header {
    max-width: 1200px;
    margin: 0 auto 36px;
    padding: 0 24px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .fd-header__left {}

  .fd-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display, 'Barlow Condensed', sans-serif);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--color-accent, #c8a84b);
    color: #fff;
    padding: 4px 14px;
    border-radius: 100px;
    margin-bottom: 12px;
  }

  .fd-title {
    font-family: var(--font-display, 'Barlow Condensed', sans-serif);
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 800;
    color: var(--color-text, #1c2b1c);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .fd-title em {
    font-style: italic;
    color: var(--color-accent, #c8a84b);
    text-transform: none;
    font-family: 'Playfair Display', Georgia, serif;
  }

  .fd-header__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    color: var(--color-primary, #1a3a1a);
    text-decoration: none;
    border-bottom: 1.5px solid rgba(26,58,26,0.25);
    padding-bottom: 2px;
    white-space: nowrap;
    transition: border-color 0.2s;
  }

  .fd-header__cta:hover { border-color: var(--color-primary, #1a3a1a); }

  /* ── TAB NAV (carrossel por categoria) ── */
  .fd-tabs {
    max-width: 1200px;
    margin: 0 auto 24px;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .fd-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    border-radius: 100px;
    font-family: var(--font-display, 'Barlow Condensed', sans-serif);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    border: 1.5px solid rgba(26,58,26,0.18);
    background: transparent;
    color: var(--color-primary, #1a3a1a);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    position: relative;
  }

  .fd-tab.is-active {
    background: var(--color-primary, #1a3a1a);
    color: #fff;
    border-color: var(--color-primary, #1a3a1a);
  }

  /* progress ring on active tab */
  .fd-tab__progress {
    display: none;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .fd-tab.is-active .fd-tab__progress { display: block; }

  .fd-tab__progress circle {
    fill: none;
    stroke: rgba(200,168,75,0.35);
    stroke-width: 2;
  }

  .fd-tab__progress .track {
    stroke: var(--color-accent, #c8a84b);
    stroke-linecap: round;
    stroke-dasharray: 38;
    stroke-dashoffset: 38;
    transform-origin: center;
    transform: rotate(-90deg);
    transition: stroke-dashoffset linear;
  }

  /* ── DISCOUNT BADGE on tab ── */
  .fd-mode-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--color-accent, #c8a84b);
    border: 1px solid var(--color-accent, #c8a84b);
    border-radius: 100px;
    padding: 5px 14px;
    font-family: var(--font-display, 'Barlow Condensed', sans-serif);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    margin-left: 4px;
  }

  .fd-mode-badge svg { width: 12px; height: 12px; fill: none; stroke: #fff; stroke-width: 2; }

  /* ── PANEL ── */
  .fd-panels {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
  }

  .fd-panel {
    display: none;
    animation: fdFadeIn 0.35s ease both;
  }

  .fd-panel.is-active { display: block; }

  @keyframes fdFadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* reutiliza .product-grid do tema */
  .fd-panel .product-grid { gap: 20px; }

  /* ── DISCOUNT BADGE no card ── */
  .fd-discount-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--color-primary, #1a3a1a);
    color: var(--color-accent, #c8a84b);
    font-family: var(--font-display, 'Barlow Condensed', sans-serif);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 6px;
    z-index: 2;
  }

  .product-card { position: relative; }

  /* ── FOOTER ── */
  .fd-footer {
    max-width: 1200px;
    margin: 32px auto 0;
    padding: 0 24px;
    text-align: center;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    .fd-section { padding: 48px 0 56px; }
    .fd-header { flex-direction: column; align-items: flex-start; }
  }
</style>

  {%- comment -%}── HEADER ──{%- endcomment -%}
  <div class="fd-header">
    <div class="fd-header__left">
      <div class="fd-eyebrow">
        {%- if has_discounts -%}Ofertas Especiais{%- else -%}Mais Vendidos{%- endif -%}
      </div>
      <h2 class="fd-title">
        Produtos em <em>Destaque</em>
      </h2>
    </div>
    <a href="{{ routes.root_url }}collections/all" class="fd-header__cta">
      Ver catálogo completo →
    </a>
  </div>

  {%- comment -%}── MODO DESCONTO ──{%- endcomment -%}
  {%- if has_discounts -%}

    <div class="fd-tabs">
      <span class="fd-mode-badge">
        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        Produtos com desconto ativo
      </span>
    </div>

    <div class="fd-panels">
      <div class="fd-panel is-active">
        {%- comment -%} Ordena por maior desconto percentual (Liquid não tem sort nativo por cálculo,
            então pré-filtramos e exibimos até 6 com compare_at_price) {%- endcomment -%}
        <div class="product-grid product-grid--3">
          {%- assign shown = 0 -%}
          {%- for product in collections.all.products -%}
            {%- if product.compare_at_price > product.price and shown < 6 -%}
              {%- assign pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
              <div style="position:relative;">
                <span class="fd-discount-badge">-{{ pct }}%</span>
                {%- render 'product-card', product: product -%}
              </div>
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

  {%- comment -%}── MODO CARROSSEL POR CATEGORIA ──{%- endcomment -%}
  {%- else -%}

    {%- if carousel_collections.size > 0 -%}
      <div class="fd-tabs" id="FdTabs">
        {%- for col_handle in carousel_collections -%}
          {%- assign col = collections[col_handle] -%}
          {%- if col.products_count > 0 -%}
            <button
              class="fd-tab {% if forloop.first %}is-active{% endif %}"
              data-panel="fd-panel-{{ col_handle }}"
              type="button"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              {{ col.title }}
              <svg class="fd-tab__progress" viewBox="0 0 14 14">
                <circle cx="7" cy="7" r="6"/>
                <circle class="track" cx="7" cy="7" r="6"/>
              </svg>
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="fd-panels" id="FdPanels">
        {%- for col_handle in carousel_collections -%}
          {%- assign col = collections[col_handle] -%}
          {%- if col.products_count > 0 -%}
            <div
              class="fd-panel {% if forloop.first %}is-active{% endif %}"
              id="fd-panel-{{ col_handle }}"
            >
              {%- comment -%} Top 3 por maior estoque (quantity) — Liquid não ordena por inventory,
                  exibimos os 3 primeiros com available=true priorizando os com maior qty -%}
              {%- endcomment -%}
              <div class="product-grid product-grid--3">
                {%- assign col_shown = 0 -%}
                {%- for product in col.products -%}
                  {%- if product.available and col_shown < 3 -%}
                    {%- render 'product-card', product: product -%}
                    {%- assign col_shown = col_shown | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- comment -%} Se não tiver 3 disponíveis, completa com indisponíveis -%}{%- endcomment -%}
                {%- if col_shown < 3 -%}
                  {%- for product in col.products -%}
                    {%- unless product.available -%}
                      {%- if col_shown < 3 -%}
                        {%- render 'product-card', product: product -%}
                        {%- assign col_shown = col_shown | plus: 1 -%}
                      {%- endif -%}
                    {%- endunless -%}
                  {%- endfor -%}
                {%- endif -%}
              </div>
              <div style="text-align:center; margin-top:20px;">
                <a href="{{ col.url }}" class="btn btn--outline">
                  Ver todos em {{ col.title }} →
                </a>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- endif -%}
  {%- endif -%}

  <div class="fd-footer">
    <a href="{{ routes.root_url }}collections/all" class="btn btn--primary btn--lg">
      Ver Catálogo Completo
    </a>
  </div>

</section>

<script>
(function () {
  var INTERVAL = 5000;
  var tabs   = Array.from(document.querySelectorAll('#FdTabs .fd-tab'));
  var panels = Array.from(document.querySelectorAll('#FdPanels .fd-panel'));

  if (!tabs.length) return;

  var current = 0;
  var timer   = null;
  var trackEl = null;

  function activate(idx) {
    tabs.forEach(function (t, i) {
      t.classList.toggle('is-active', i === idx);
      t.setAttribute('aria-selected', i === idx);
    });
    panels.forEach(function (p, i) {
      p.classList.toggle('is-active', i === idx);
    });
    current = idx;
    startTrack();
  }

  function next() {
    activate((current + 1) % tabs.length);
  }

  function startTrack() {
    // anima o círculo SVG do tab ativo
    if (trackEl) { trackEl.style.transition = 'none'; trackEl.style.strokeDashoffset = 38; }
    var activeTab = tabs[current];
    trackEl = activeTab ? activeTab.querySelector('.track') : null;
    if (!trackEl) return;
    // força reflow
    trackEl.getBoundingClientRect();
    trackEl.style.transition = 'stroke-dashoffset ' + INTERVAL + 'ms linear';
    trackEl.style.strokeDashoffset = 0;
  }

  function startTimer() {
    clearInterval(timer);
    timer = setInterval(next, INTERVAL);
  }

  // clicks manuais
  tabs.forEach(function (tab, idx) {
    tab.addEventListener('click', function () {
      clearInterval(timer);
      activate(idx);
      startTimer();
    });
  });

  // pausa no hover
  var section = document.getElementById('FeaturedSection');
  if (section) {
    section.addEventListener('mouseenter', function () { clearInterval(timer); });
    section.addEventListener('mouseleave', function () { startTimer(); });
  }

  activate(0);
  startTimer();
})();
</script>

{% schema %}
{
  "name": "Produtos em Destaque",
  "settings": [],
  "presets": [{ "name": "Produtos em Destaque" }]
}
{% endschema %}
