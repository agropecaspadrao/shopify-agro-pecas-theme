<style>
  .footer-social {
    display: flex;
    gap: 10px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  .footer-social__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1.5px solid rgba(200,168,75,0.3);
    color: rgba(245,238,220,0.6);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .footer-social__link:hover {
    border-color: var(--color-accent, #c8a84b);
    color: var(--color-accent, #c8a84b);
    background: rgba(200,168,75,0.08);
  }

  .footer-social__link svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
</style>

<footer class="site-footer">
  <div class="footer-main">
    <div class="page-width footer-grid">

      <!-- Brand col -->
      <div class="footer-brand">
        <div class="footer-logo">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" width="160" height="auto" loading="lazy">
          {%- else -%}
            <span class="footer-logo__text">{{ shop.name }}</span>
          {%- endif -%}
        </div>
        <p class="footer-tagline">{{ settings.footer_tagline }}</p>
        <div class="footer-contact">
          {%- if settings.store_cnpj != blank -%}
            <p><strong>CNPJ:</strong> {{ settings.store_cnpj }}</p>
          {%- endif -%}
          {%- if settings.store_address != blank -%}
            <p>{{ settings.store_address }}</p>
          {%- endif -%}
          {%- if settings.store_phone != blank -%}
            <p><a href="tel:{{ settings.store_phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}">{{ settings.store_phone }}</a></p>
          {%- endif -%}
          {%- if settings.store_email != blank -%}
            <p><a href="mailto:{{ settings.store_email }}">{{ settings.store_email }}</a></p>
          {%- endif -%}
        </div>

        {%- assign has_social = false -%}
        {%- if section.settings.instagram != blank or section.settings.facebook != blank or section.settings.linkedin != blank or section.settings.youtube != blank -%}
          {%- assign has_social = true -%}
        {%- endif -%}

        {%- if has_social -%}
          <div class="footer-social">
            {%- if section.settings.instagram != blank -%}
              <a href="{{ section.settings.instagram }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="Instagram">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.facebook != blank -%}
              <a href="{{ section.settings.facebook }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="Facebook">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.linkedin != blank -%}
              <a href="{{ section.settings.linkedin }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if section.settings.youtube != blank -%}
              <a href="{{ section.settings.youtube }}" class="footer-social__link" target="_blank" rel="noopener" aria-label="YouTube">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Link cols -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer-links" {{ block.shopify_attributes }}>
            <h4 class="footer-links__title">{{ block.settings.heading }}</h4>
            <ul>
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- elsif block.type == 'contact' -%}
          <div class="footer-contact-block" {{ block.shopify_attributes }}>
            <h4 class="footer-links__title">{{ block.settings.heading }}</h4>
            <p>{{ block.settings.description }}</p>
            <a href="https://wa.me/{{ settings.whatsapp_number }}" class="btn btn--whatsapp btn--sm" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chamar no WhatsApp
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>

  <div class="footer-bottom">
    <div class="page-width footer-bottom__inner">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos os direitos reservados.</p>
      <div class="footer-badges">
        <span class="trust-badge">ISO 9001</span>
        <span class="trust-badge">ISO 14001</span>
        <span class="trust-badge">OHSAS 18001</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Rodapé",
  "max_blocks": 6,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo no Rodapé"
    },
    {
      "type": "header",
      "content": "Redes Sociais"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook"
    },
    {
      "type": "url",
      "id": "linkedin",
      "label": "LinkedIn"
    },
    {
      "type": "url",
      "id": "youtube",
      "label": "YouTube"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu de Links",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contato",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Atendimento"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrição",
          "default": "Atendemos distribuidores, revendas e frota própria em todo o Brasil."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rodapé Padrão",
      "blocks": [
        {
          "type": "link_list",
          "settings": {
            "heading": "Produtos",
            "menu": "footer-produtos"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "heading": "Institucional",
            "menu": "footer-institucional"
          }
        },
        {
          "type": "contact",
          "settings": {
            "heading": "Atendimento"
          }
        }
      ]
    }
  ]
}
{% endschema %}
