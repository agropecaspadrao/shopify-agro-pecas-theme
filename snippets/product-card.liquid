{%- liquid
  assign sku_livenza = product.metafields.agro.sku_livenza.value
  assign part_number = product.metafields.agro.part_number.value
  assign wa_sku      = sku_livenza | default: product.variants.first.sku
  assign wa_msg      = 'Olá! Tenho interesse na peça *' | append: product.title | append: '* (SKU: ' | append: wa_sku | append: ') do catálogo Agro Peças Padrão. Gostaria de saber preço e disponibilidade.'
  assign has_price   = false
  if product.price > 0
    assign has_price = true
  endif
  assign has_stock = false
  if product.available and product.variants.first.inventory_quantity > 0
    assign has_stock = true
  endif
-%}

<article class="product-card">
  <a href="{{ product.url }}" class="product-card__img-link" tabindex="-1" aria-hidden="true">
    <div class="product-card__img-wrap">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 400 }}"
          alt="{{ product.featured_image.alt | default: product.title }}"
          width="400" height="400" loading="lazy"
          class="product-card__img"
        >
      {%- else -%}
        <div class="product-card__img-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-6-6L5 21"/>
          </svg>
        </div>
      {%- endif -%}

      {%- if has_price and has_stock -%}
        <span class="product-card__badge product-card__badge--stock">Em Estoque</span>
      {%- elsif has_price -%}
        <span class="product-card__badge product-card__badge--consult">Sob Consulta</span>
      {%- endif -%}
    </div>
  </a>

  <div class="product-card__body">
    {%- if product.type != blank -%}
      <span class="product-card__type">{{ product.type }}</span>
    {%- endif -%}

    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    <div class="product-card__codes">
      {%- if sku_livenza != blank -%}
        <span class="product-card__sku">{{ sku_livenza }}</span>
      {%- elsif product.variants.first.sku != blank -%}
        <span class="product-card__sku">{{ product.variants.first.sku }}</span>
      {%- endif -%}
      {%- if part_number != blank -%}
        <span class="product-card__oem">OEM: {{ part_number }}</span>
      {%- endif -%}
    </div>

    <!-- Preço ou "Sob consulta" -->
    {%- if has_price -%}
      <div class="product-card__price">
        {%- if product.compare_at_price > product.price -%}
          <span class="product-card__price-compare">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="product-card__price-current">{{ product.price | money }}</span>
      </div>
    {%- else -%}
      <div class="product-card__price product-card__price--consult">
        <span>Preço sob consulta</span>
      </div>
    {%- endif -%}

    <!-- CTAs -->
    <div class="product-card__ctas">
      {%- if has_price and has_stock -%}
        {%- form 'product', product -%}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" name="add" class="btn btn--primary btn--sm btn--full product-card__add-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 001.98 1.61h9.72a2 2 0 001.98-1.61L23 6H6"/></svg>
            Adicionar ao Carrinho
          </button>
        {%- endform -%}
      {%- else -%}
        <a href="/pages/contato?product={{ product.title | url_encode }}&sku={{ wa_sku | url_encode }}"
           class="btn btn--primary btn--sm btn--full">
          Solicitar Cotação
        </a>
      {%- endif -%}
      <a href="{{ product.url }}" class="btn btn--outline btn--sm">Ver Detalhes</a>
    </div>
  </div>
</article>
