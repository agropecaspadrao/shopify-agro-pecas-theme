<div class="search-page">
  <div class="page-width">
    <div class="search-header">
      <h1 class="search-header__title">
        {%- if search.performed -%}
          Resultados para "{{ search.terms }}"
        {%- else -%}
          Buscar Peças
        {%- endif -%}
      </h1>

      <form action="{{ routes.search_url }}" method="get" class="search-page__form" role="search">
        <input type="hidden" name="type" value="product">
        <div class="search-page__input-wrap">
          <input
            type="search"
            name="q"
            class="search-page__input"
            placeholder="Nome, SKU, referência OEM, modelo do trator..."
            value="{{ search.terms | escape }}"
            aria-label="Buscar"
            autofocus
          >
          <button type="submit" class="btn btn--primary">Buscar</button>
        </div>
      </form>
    </div>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="search-count">{{ search.results_count }} {{ search.results_count | pluralize: 'resultado encontrado', 'resultados encontrados' }}</p>
        <div class="product-grid product-grid--3">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- render 'product-card', product: item -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if search.pages_count > 1 -%}
          {%- paginate search.results by 12 -%}
            <nav class="pagination" aria-label="Paginação">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="pagination__btn">← Anterior</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="pagination__btn">{{ part.title }}</a>
                {%- else -%}
                  <span class="pagination__current">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="pagination__btn">Próxima →</a>
              {%- endif -%}
            </nav>
          {%- endpaginate -%}
        {%- endif -%}
      {%- else -%}
        <div class="search-empty">
          <div class="search-empty__icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </div>
          <h2>Não encontramos "{{ search.terms }}"</h2>
          <p>Não encontrou? Nossa equipe encontra pra você.</p>
          <div class="search-empty__tips">
            <p><strong>Dicas de busca:</strong></p>
            <ul>
              <li>Número de série do trator: ex. "6620", "T6.120", "4299"</li>
              <li>Número OEM do fabricante: ex. "RE73947", "FONN600BB"</li>
              <li>SKU Livenza: ex. "5.1305.0565071"</li>
              <li>Marca: "john deere", "new holland", "massey"</li>
            </ul>
          </div>
          <a href="https://wa.me/5541998333338?text={{ 'Olá! Não encontrei a peça que preciso no site. Estou buscando por: ' | append: search.terms | url_encode }}"
             class="btn btn--whatsapp btn--lg"
             target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Nossa equipe encontra pra você
          </a>
        </div>
      {%- endif -%}
    {%- else -%}
      <!-- No search performed yet -->
      <div class="search-placeholder">
        <p>Use a busca acima para encontrar peças pelo modelo do trator, SKU ou referência OEM.</p>
        <div class="search-categories">
          <h3>Navegar por Categoria</h3>
          <div class="search-category-links">
            <a href="{{ routes.collections_url }}/bombas-hidraulicas" class="search-category-link">Bombas Hidráulicas</a>
            <a href="{{ routes.collections_url }}/sensores-agricolas" class="search-category-link">Sensores Agrícolas</a>
            <a href="{{ routes.collections_url }}" class="search-category-link">Ver Todas</a>
          </div>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Página de Busca",
  "settings": []
}
{% endschema %}
